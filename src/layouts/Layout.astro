---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title?: string;
  description?: string;
}
const { title = "AnwyMed", description = "Complete Clinic Management Software for Modern Healthcare Practices" } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>AnwyMed</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen text-gray-900 antialiased bg-dot-pattern">
    <Header />

    <main>
      <slot />
    </main>

    <Footer />
  </body>
</html>