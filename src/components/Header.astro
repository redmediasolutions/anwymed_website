---
// Header.astro - Navigation Header Component
---

<header id="nav-wrapper" class="sticky top-0 z-50 glass-panel border-b border-slate-200/80 transition-all duration-300">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      <a href="/" class="flex items-center space-x-3 group">
        <img src="/anwymed logo.png" alt="AnwyMed Logo" class="w-10 h-10 transform group-hover:scale-105 transition-transform duration-300">
        <span class="text-xl font-bold tracking-tight text-slate-900">Anwy<span class="text-blue-600">Med</span></span>
      </a>

      <div class="hidden lg:flex items-center space-x-10">
        <div class="relative group" id="features-dropdown">
          <button
            id="features-btn"
            class="flex items-center space-x-1 font-medium text-slate-600 hover:text-blue-600 transition-colors py-2"
            aria-expanded="false"
          >
            <span>Features</span>
            <svg class="w-4 h-4 transition-transform duration-200" id="features-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div
            id="features-menu"
            class="hidden absolute top-full left-1/2 -translate-x-1/3 mt-2 w-80 bg-white/95 backdrop-blur-md rounded-2xl shadow-2xl border border-slate-100 p-3 grid grid-cols-1 gap-1 z-50 animate-in fade-in slide-in-from-top-2 duration-200 group-hover:block"
          >
            <a href="/appointment-management" class="block px-4 py-2.5 rounded-xl hover:bg-blue-50/80 text-sm font-medium text-slate-700 hover:text-blue-700 transition-colors">Appointment Management</a>
            <a href="/patient-management" class="block px-4 py-2.5 rounded-xl hover:bg-blue-50/80 text-sm font-medium text-slate-700 hover:text-blue-700 transition-colors">Patient Management</a>
            <a href="/consultation-management" class="block px-4 py-2.5 rounded-xl hover:bg-blue-50/80 text-sm font-medium text-slate-700 hover:text-blue-700 transition-colors">Consultation Management</a>
            <a href="/vitals-management" class="block px-4 py-2.5 rounded-xl hover:bg-blue-50/80 text-sm font-medium text-slate-700 hover:text-blue-700 transition-colors">Vitals Management</a>
            <a href="/prescription-management" class="block px-4 py-2.5 rounded-xl hover:bg-blue-50/80 text-sm font-medium text-slate-700 hover:text-blue-700 transition-colors">Prescription Management</a>
            <a href="/medical-procedures" class="block px-4 py-2.5 rounded-xl hover:bg-blue-50/80 text-sm font-medium text-slate-700 hover:text-blue-700 transition-colors">Medical Procedures</a>
            <a href="/billing-invoicing" class="block px-4 py-2.5 rounded-xl hover:bg-blue-50/80 text-sm font-medium text-slate-700 hover:text-blue-700 transition-colors">Billing &amp; Invoicing</a>
            <a href="/inventory-management" class="block px-4 py-2.5 rounded-xl hover:bg-blue-50/80 text-sm font-medium text-slate-700 hover:text-blue-700 transition-colors">Inventory Management</a>
            <a href="/batch-management" class="block px-4 py-2.5 rounded-xl hover:bg-blue-50/80 text-sm font-medium text-slate-700 hover:text-blue-700 transition-colors">Batch Management</a>
            <a href="/follow-up-management" class="block px-4 py-2.5 rounded-xl hover:bg-blue-50/80 text-sm font-medium text-slate-700 hover:text-blue-700 transition-colors">Follow-Up Management</a>
            <a href="/medical-attachments" class="block px-4 py-2.5 rounded-xl hover:bg-blue-50/80 text-sm font-medium text-slate-700 hover:text-blue-700 transition-colors">Medical Attachments</a>
            <a href="/user-staff-management" class="block px-4 py-2.5 rounded-xl hover:bg-blue-50/80 text-sm font-medium text-slate-700 hover:text-blue-700 transition-colors">User &amp; Staff Management</a>
            <a href="/multi-tenant" class="block px-4 py-2.5 rounded-xl hover:bg-blue-50/80 text-sm font-medium text-slate-700 hover:text-blue-700 transition-colors">Multi-Tenant Platform</a>
            <a href="/cloud-security" class="block px-4 py-2.5 rounded-xl hover:bg-blue-50/80 text-sm font-medium text-slate-700 hover:text-blue-700 transition-colors">Cloud Security</a>
          </div>
        </div>
        <a href="/#solutions" class="font-medium text-slate-600 hover:text-blue-600 transition-colors">Solutions</a>
        <a href="/#pricing" class="font-medium text-slate-600 hover:text-blue-600 transition-colors">Pricing</a>
        <a href="/book-demo" class="font-medium text-slate-600 hover:text-blue-600 transition-colors">Contact</a>
      </div>

      <div class="hidden lg:flex items-center space-x-4">
        <a href="/book-demo" class="px-6 py-3 bg-gradient-to-r from-blue-600 to-blue-700 text-white font-semibold rounded-xl shadow-md shadow-blue-500/10 hover:shadow-lg hover:shadow-blue-500/20 hover:-translate-y-0.5 transition-all duration-200">Book Demo</a>
      </div>

      <button id="mobile-menu-btn" class="lg:hidden p-2 text-slate-700 hover:bg-slate-50 rounded-xl transition-colors" aria-label="Toggle menu">
        <svg id="icon-open" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="icon-close" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <div id="mobile-menu" class="hidden lg:hidden border-t border-slate-100 bg-white/95 backdrop-blur-md max-h-[calc(100vh-5rem)] overflow-y-auto">
      <div class="px-4 py-6 space-y-4">
        <div>
          <button
            id="mobile-features-btn"
            class="flex items-center justify-between w-full text-slate-900 font-semibold py-2"
          >
            <span>Features</span>
            <svg class="w-5 h-5 transition-transform duration-200" id="mobile-features-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div id="mobile-features-menu" class="hidden pl-4 border-l-2 border-slate-100 space-y-1 mt-2">
            <a href="/appointment-management" class="block py-2 text-sm font-medium text-slate-600 hover:text-blue-600">Appointment Management</a>
            <a href="/patient-management" class="block py-2 text-sm font-medium text-slate-600 hover:text-blue-600">Patient Management</a>
            <a href="/consultation-management" class="block py-2 text-sm font-medium text-slate-600 hover:text-blue-600">Consultation Management</a>
            <a href="/vitals-management" class="block py-2 text-sm font-medium text-slate-600 hover:text-blue-600">Vitals Management</a>
            <a href="/prescription-management" class="block py-2 text-sm font-medium text-slate-600 hover:text-blue-600">Prescription Management</a>
            <a href="/medical-procedures" class="block py-2 text-sm font-medium text-slate-600 hover:text-blue-600">Medical Procedures</a>
            <a href="/billing-invoicing" class="block py-2 text-sm font-medium text-slate-600 hover:text-blue-600">Billing &amp; Invoicing</a>
            <a href="/inventory-management" class="block py-2 text-sm font-medium text-slate-600 hover:text-blue-600">Inventory Management</a>
            <a href="/batch-management" class="block py-2 text-sm font-medium text-slate-600 hover:text-blue-600">Batch Management</a>
            <a href="/follow-up-management" class="block py-2 text-sm font-medium text-slate-600 hover:text-blue-600">Follow-Up Management</a>
            <a href="/medical-attachments" class="block py-2 text-sm font-medium text-slate-600 hover:text-blue-600">Medical Attachments</a>
            <a href="/user-staff-management" class="block py-2 text-sm font-medium text-slate-600 hover:text-blue-600">User &amp; Staff Management</a>
            <a href="/multi-tenant" class="block py-2 text-sm font-medium text-slate-600 hover:text-blue-600">Multi-Tenant Platform</a>
            <a href="/cloud-security" class="block py-2 text-sm font-medium text-slate-600 hover:text-blue-600">Cloud Security</a>
          </div>
        </div>
        <a href="/#solutions" class="block font-semibold text-slate-700 py-2">Solutions</a>
        <a href="/#pricing" class="block font-semibold text-slate-700 py-2">Pricing</a>
        <a href="/book-demo" class="block font-semibold text-slate-700 py-2">Contact</a>
        <div class="pt-4">
          <a href="/book-demo" class="block w-full text-center px-4 py-3.5 bg-blue-600 text-white font-semibold rounded-xl shadow-md">Book Demo</a>
        </div>
      </div>
    </div>
  </nav>
</header>

<script>
  // Desktop Dropdown with proper hover handling
  const featuresDropdown = document.getElementById('features-dropdown');
  const featuresBtn = document.getElementById('features-btn');
  const featuresMenu = document.getElementById('features-menu');
  const featuresChevron = document.getElementById('features-chevron');

  if (featuresDropdown && featuresMenu) {
    featuresDropdown.addEventListener('mouseenter', () => {
      featuresMenu.classList.remove('hidden');
      featuresChevron?.classList.add('rotate-180');
    });
    
    featuresDropdown.addEventListener('mouseleave', () => {
      featuresMenu.classList.add('hidden');
      featuresChevron?.classList.remove('rotate-180');
    });
  }

  // Mobile Menu Toggle
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  mobileMenuBtn?.addEventListener('click', () => {
    const isHidden = mobileMenu?.classList.contains('hidden');
    mobileMenu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden', !isHidden);
    iconClose?.classList.toggle('hidden', isHidden);
  });

  // Mobile Accordion Toggle
  const mobileFeaturesBtn = document.getElementById('mobile-features-btn');
  const mobileFeaturesMenu = document.getElementById('mobile-features-menu');
  const mobileFeaturesChevron = document.getElementById('mobile-features-chevron');

  mobileFeaturesBtn?.addEventListener('click', () => {
    mobileFeaturesMenu?.classList.toggle('hidden');
    mobileFeaturesChevron?.classList.toggle('rotate-180');
  });
</script>
