---
export interface Props {
  iconSvg: string;
  title: string;
  subtitle: string;
  description: string;
  features: string[];
  benefits: string[];
}

const { iconSvg, title, subtitle, description, features, benefits } = Astro.props;
---

<div class="min-h-screen bg-slate-50/50">
  <div class="relative overflow-hidden bg-white border-b border-slate-200/60 px-4 sm:px-6 lg:px-8 py-16 md:py-24">
    <div class="max-w-7xl mx-auto">
      <a href="/" class="inline-flex items-center text-sm font-semibold text-blue-600 hover:text-blue-700 mb-10 group">
        <svg class="w-4 h-4 mr-2 group-hover:-translate-x-1 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Return to Platform Control Panel
      </a>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <div class="w-14 h-14 bg-gradient-to-br from-blue-50 to-blue-100/80 rounded-2xl flex items-center justify-center mb-6 text-blue-600 shadow-inner">
            <Fragment set:html={iconSvg} />
          </div>
          <h1 class="text-3xl md:text-5xl font-extrabold tracking-tight text-slate-900 mb-4">{title}</h1>
          <p class="text-lg md:text-xl font-medium text-blue-600/90 mb-6 leading-relaxed">{subtitle}</p>
          <p class="text-base md:text-lg text-slate-600 leading-relaxed max-w-2xl">{description}</p>
        </div>

        <div class="relative lg:h-full flex items-center justify-center">
          <div class="absolute inset-0 bg-gradient-to-tr from-blue-600/5 to-cyan-500/5 rounded-3xl transform rotate-1 scale-105"></div>
          <div class="relative w-full bg-gradient-to-br from-slate-900 to-slate-800 rounded-3xl p-8 md:p-12 shadow-2xl min-h-[320px] flex items-center justify-center border border-slate-700/50 overflow-hidden">
            <div class="absolute inset-0 opacity-10 bg-dot-pattern"></div>
            <div class="w-32 h-32 text-blue-400 opacity-20 transform -rotate-12 scale-150 animate-float">
              <Fragment set:html={iconSvg} />
            </div>
            <div class="absolute bottom-6 left-6 right-6 bg-white/5 backdrop-blur-md rounded-xl p-4 border border-white/10 flex items-center space-x-3">
              <div class="w-3 h-3 rounded-full bg-emerald-500 animate-pulse"></div>
              <p class="text-xs font-semibold text-slate-300 tracking-wide uppercase">Core Module Active & Verified</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <section class="px-4 sm:px-6 lg:px-8 py-16 md:py-24">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        
        <div class="bg-white rounded-3xl p-8 md:p-10 border border-slate-200/60 shadow-sm shadow-slate-100">
          <h2 class="text-2xl font-bold text-slate-900 mb-2">Functional Capabilities</h2>
          <p class="text-sm text-slate-500 mb-8">Granular parameters configured natively inside this utility module.</p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {features.map((feature) => (
              <div class="flex items-start space-x-3 p-3 rounded-xl hover:bg-slate-50 transition-colors duration-200">
                <div class="w-5 h-5 bg-blue-50 rounded-md flex items-center justify-center text-blue-600 mt-0.5 flex-shrink-0">
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <span class="text-sm font-medium text-slate-700 leading-tight">{feature}</span>
              </div>
            ))}
          </div>
        </div>

        <div>
          <h2 class="text-2xl font-bold text-slate-900 mb-2">Operational Impact</h2>
          <p class="text-sm text-slate-500 mb-8">Measurable workflow improvements tracking implementation.</p>
          <div class="space-y-4">
            {benefits.map((benefit) => (
              <div class="bg-white rounded-2xl p-6 border border-slate-200/60 shadow-sm hover:shadow-md transition-all duration-300 flex items-start space-x-4 group">
                <div class="w-10 h-10 bg-gradient-to-br from-emerald-50 to-emerald-100 rounded-xl flex items-center justify-center text-emerald-600 flex-shrink-0 group-hover:scale-105 transition-transform">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                  </svg>
                </div>
                <p class="text-sm font-medium text-slate-700 leading-relaxed pt-1.5">{benefit}</p>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <section class="px-4 sm:px-6 lg:px-8 pb-24">
    <div class="max-w-7xl mx-auto">
      <div class="relative bg-slate-950 rounded-3xl p-8 md:p-16 shadow-2xl overflow-hidden border border-slate-800 text-center">
        <div class="absolute inset-0 opacity-5 bg-dot-pattern"></div>
        <div class="relative z-10 max-w-2xl mx-auto">
          <h2 class="text-2xl md:text-4xl font-bold text-white mb-4">Ready to Run a Highly Optimized Clinic?</h2>
          <p class="text-sm md:text-base text-slate-400 mb-10 leading-relaxed">Schedule an engineering overview. Explore how the <span class="text-blue-400 font-semibold">{title}</span> architecture plugs perfectly into your clinical operations.</p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/book-demo" class="px-8 py-4 bg-blue-600 text-white font-semibold rounded-xl hover:bg-blue-500 transition-all shadow-lg shadow-blue-600/20 hover:shadow-blue-600/30 hover:-translate-y-0.5">Initialize Setup & Demo</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</div>